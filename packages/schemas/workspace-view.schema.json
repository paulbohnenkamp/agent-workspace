{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-workspace.dev/schemas/workspace-view.schema.json",
  "title": "Workspace View",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "route", "layout", "regions"],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "route": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "shell": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "header": {
          "type": "object",
          "additionalProperties": true
        },
        "chrome": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "fields": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/field"
      }
    },
    "layout": {
      "$ref": "#/$defs/layout"
    },
    "regions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/viewNode"
        }
      }
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source"],
      "properties": {
        "name": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "select": {
          "type": "object",
          "additionalProperties": true
        },
        "defaultValue": {}
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "columns", "regions"],
      "properties": {
        "type": {
          "const": "grid"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "gap": {
          "type": "string"
        },
        "regions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/layoutRegion"
          }
        }
      }
    },
    "layoutRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string"
        },
        "columnStart": {
          "type": "integer",
          "minimum": 1
        },
        "columnSpan": {
          "type": "integer",
          "minimum": 1
        },
        "rowStart": {
          "type": "integer",
          "minimum": 1
        },
        "rowSpan": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "viewNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component"],
      "properties": {
        "component": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "tabs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bind": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
