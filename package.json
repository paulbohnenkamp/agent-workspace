{
  "name": "agent-workspace-platform",
  "version": "0.0.1",
  "description": "Agent Workspace Platform - metadata-driven collaborative AI workspaces",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@awp/types && npm run build --workspace=@awp/loader && npm run build --workspace=@awp/tools && npm run build --workspace=@awp/runtime && npm run build --workspace=@awp/schemas",
    "build:workspace": "tsc -p tsconfig.workspace.json",
    "test": "jest --config ./jest.config.cjs",
    "workspace": "npm run build:workspace && node build/src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^65.0.1",
    "jest": "^30.0.5",
    "json-schema-to-typescript": "^13.0.0",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
