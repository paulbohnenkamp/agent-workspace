{
  "extends": "../view.json",
  "renderer": "react",
  "regions": {
    "assistant": [
      {
        "component": "summaryCard",
        "title": "AI Assistant",
        "bind": {
          "candidate": "$fields.selectedCandidate",
          "artifact": "$fields.candidateEvaluation"
        }
      },
      {
        "component": "timeline",
        "title": "Discussion",
        "bind": {
          "thread": "$fields.candidateThread"
        }
      },
      {
        "component": "composer",
        "bind": {
          "thread": "$fields.candidateThread"
        }
      }
    ],
    "main": [
      {
        "component": "header",
        "bind": {
          "candidate": "$fields.selectedCandidate"
        }
      },
      {
        "component": "tabs",
        "tabs": [
          "evaluation-summary",
          "interview-brief",
          "follow-up-draft",
          "scorecard"
        ],
        "bind": {
          "artifact": "$fields.candidateEvaluation"
        }
      }
    ]
  }
}
