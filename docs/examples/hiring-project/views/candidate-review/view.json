{
  "id": "candidate-review-workspace",
  "title": "Candidate Review",
  "route": "/candidates/:candidateId/review",
  "description": "Artifact-centric workspace for reviewing one candidate across queue state, AI collaboration, evaluation artifacts, and approval actions.",
  "shell": {
    "type": "workspace-shell",
    "header": {
      "component": "header"
    },
    "chrome": {
      "leftNav": true,
      "topTabs": ["workspace", "my-tasks", "knowledge", "analytics"]
    }
  },
  "context": {
    "projectId": "hiring-project",
    "selection": {
      "candidateId": "$route.candidateId"
    }
  },
  "fields": [
    {
      "name": "selectedCandidateId",
      "source": "$route.candidateId"
    },
    {
      "name": "selectedCandidate",
      "source": "projection.item_queue",
      "select": {
        "id": "$fields.selectedCandidateId"
      }
    },
    {
      "name": "candidateEvaluation",
      "source": "projection.artifact_versions",
      "select": {
        "artifactType": "candidate-evaluation",
        "artifactId": "$fields.selectedCandidateId"
      }
    },
    {
      "name": "candidateThread",
      "source": "projection.thread_index",
      "select": {
        "threadFor": "candidate:$fields.selectedCandidateId"
      }
    },
    {
      "name": "candidateRuns",
      "source": "projection.agent_activity",
      "select": {
        "relatedTo": "candidate:$fields.selectedCandidateId"
      }
    },
    {
      "name": "candidateSources",
      "source": "projection.knowledge_links",
      "select": {
        "relatedTo": "candidate:$fields.selectedCandidateId"
      }
    }
  ],
  "layout": {
    "type": "grid",
    "columns": [
      "minmax(18rem, 20rem)",
      "minmax(18rem, 20rem)",
      "minmax(0, 1fr)",
      "minmax(16rem, 18rem)"
    ],
    "gap": "0",
    "regions": [
      {
        "id": "queue",
        "columnStart": 1,
        "columnSpan": 1
      },
      {
        "id": "assistant",
        "columnStart": 2,
        "columnSpan": 1
      },
      {
        "id": "main",
        "columnStart": 3,
        "columnSpan": 1
      },
      {
        "id": "context",
        "columnStart": 4,
        "columnSpan": 1
      }
    ]
  },
  "regions": {
    "queue": [
      {
        "component": "queue",
        "title": "Candidate Review Queue",
        "bind": {
          "projection": "item_queue",
          "selectedId": "$fields.selectedCandidateId",
          "total": 12
        }
      }
    ],
    "assistant": [
      {
        "component": "timeline",
        "title": "Chat",
        "bind": {
          "thread": "$fields.candidateThread"
        }
      },
      {
        "component": "composer",
        "bind": {
          "thread": "$fields.candidateThread"
        }
      }
    ],
    "main": [
      {
        "component": "header",
        "bind": {
          "candidate": "$fields.selectedCandidate"
        }
      },
      {
        "component": "tabs",
        "tabs": ["evaluation-summary", "interview-brief", "follow-up-draft", "scorecard"],
        "bind": {
          "artifact": "$fields.candidateEvaluation"
        }
      }
    ],
    "context": [
      {
        "component": "sources",
        "title": "Knowledge Sources",
        "bind": {
          "sources": "$fields.candidateSources"
        }
      },
      {
        "component": "statusList",
        "title": "Agents",
        "bind": {
          "runs": "$fields.candidateRuns"
        }
      },
      {
        "component": "actions",
        "title": "Actions",
        "actions": [
          {
            "label": "Schedule Interview",
            "variant": "primary"
          },
          {
            "label": "Add Reviewer",
            "variant": "secondary"
          },
          {
            "label": "Refresh Summary",
            "variant": "secondary"
          }
        ],
        "bind": {
          "candidateId": "$fields.selectedCandidateId"
        }
      }
    ]
  }
}
